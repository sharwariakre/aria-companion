# Local development — use this when running the backend in a venv on your Mac
# (DB is still in Docker, mapped to localhost:5433)
#
# Copy to .env.local and fill in your values:
#   cp .env.local.example .env.local

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email alerts (Gmail SMTP)
ALERT_EMAIL_FROM=you@gmail.com
ALERT_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL_TO=family@example.com

# Database — localhost because backend runs on your Mac
DATABASE_URL=postgresql+asyncpg://aria:aria@localhost:5433/aria_db

# App
BASE_URL=https://your-ngrok-url.ngrok-free.app
SECRET_KEY=changeme-use-a-real-secret-in-prod
AUDIO_DIR=./audio

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
