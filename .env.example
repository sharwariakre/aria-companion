# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email alerts (Gmail SMTP)
ALERT_EMAIL_FROM=you@gmail.com
ALERT_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx   # Gmail App Password (not your login password)
ALERT_EMAIL_TO=family@example.com

# App
BASE_URL=https://your-ngrok-url.ngrok-free.app   # ngrok tunnel URL for Twilio webhooks
SECRET_KEY=changeme-use-a-real-secret-in-prod
AUDIO_DIR=./audio

# ---------------------------------------------------------------
# Database — choose the correct URL for your environment:
#
#   Local venv (backend running on your Mac, DB in Docker):
DATABASE_URL=postgresql+asyncpg://aria:aria@localhost:5433/aria_db
#
#   Docker (backend container, DB container on internal network):
#   DATABASE_URL=postgresql+asyncpg://aria:aria@db:5432/aria_db
#   Note: docker-compose.yml overrides this automatically for Docker,
#   so you do not need to change this line when using Docker.
# ---------------------------------------------------------------

# Ollama (only needed for background tasks — memory extraction, sentiment scoring)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
